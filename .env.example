# ============ 应用配置 ============
APP_NAME=AI-RAG-Assistant
APP_VERSION=1.0.0
DEBUG=true

# ============ 数据库 ============
DATABASE_URL=sqlite:///data/app.db

# ============ 文件存储 ============
UPLOAD_DIR=data/uploads
PROCESSED_DIR=data/processed
FAISS_INDEX_DIR=data/faiss_index
MAX_FILE_SIZE_MB=50

# ============ 分块配置 ============
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ============ 检索配置 ============
TOP_K_CANDIDATES=10
TOP_N_FINAL=5
SIMILARITY_THRESHOLD=0.3
HISTORY_TURNS=3

# ============ Embedding ============
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# ============ Rerank ============
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_DEVICE=cpu
RERANK_ENABLED=true

# ============ LLM ============
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-ranJ0nzEZtTKJZHCdML07vrk3iic26yZj4wmdwTkdaLAVI7y
LLM_BASE_URL=https://www.moxin.online/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=60
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# ============ 日志 ============
LOG_LEVEL=INFO
LOG_DIR=logs
