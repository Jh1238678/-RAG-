# 应用配置
APP_NAME=AI-RAG-Assistant
APP_VERSION=1.0.0
DEBUG=True

# 数据库
DATABASE_URL=sqlite:///data/app.db

# 文件存储
UPLOAD_DIR=data/uploads
PROCESSED_DIR=data/processed
FAISS_INDEX_DIR=data/faiss_index
MAX_FILE_SIZE_MB=50

# 分块
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# 检索
TOP_K_CANDIDATES=10
TOP_N_FINAL=5
SIMILARITY_THRESHOLD=0.3
HISTORY_TURNS=3

# Embedding（本地模型路径）
EMBEDDING_MODEL=models/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# Rerank（本地模型路径）
RERANK_MODEL=models/bge-reranker-base
RERANK_DEVICE=cpu
RERANK_ENABLED=True

# HuggingFace 镜像（备用）
HF_ENDPOINT=https://hf-mirror.com

# LLM（需要填入你的 DeepSeek API Key）
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-AY0cfmnLIeiSXvzESXUqBzQqz2SQaJGFp7F3zdk5FtHpu1B1
LLM_BASE_URL=https://www.moxin.online/v1
LLM_MODEL=[次]gemini-2.5-pro
LLM_TIMEOUT=60
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# 日志
LOG_LEVEL=INFO
LOG_DIR=logs
